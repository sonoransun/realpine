# ===== Build output =====

# CMake build directories (build/, build-ci/, build-baseline/, build_dir/, _build/, ...)
build*/
_build/
**/_deps/

# CMake generated files (when accidentally placed outside build tree)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CPackConfig.cmake
CPackSourceConfig.cmake
CTestTestfile.cmake
DartConfiguration.tcl
CMakeConfigureLog.yaml
install_manifest.txt
Testing/

# Generated pkg-config files (*.pc.in templates are tracked)
*.pc
!packaging/**/*.pc.in

# Compiled objects
*.o
*.d
*.obj

# Legacy Makefile object directories
.obj*/

# Libraries
*.a
*.so
*.so.*
*.dylib
*.lib
*.dll
*.exp

# Per-module lib/ directories (legacy Makefile output)
# Top-level lib/ is also build output
lib/
*/lib/*.a
*/lib/*.so
*/*/lib/*.a
*/*/lib/*.so

# Per-module bin/ directories (legacy Makefile output)
bin/
*/bin/
*/*/bin/

# Precompiled headers
*.gch
*.pch

# ===== Vendored / fetched third-party =====

AlpineGui/vendor/
**/vendor/
**/third_party/
**/third-party/
**/external/

# ===== Profiling & coverage =====

*.gcda
*.gcno
*.gcov
gmon.out
*.info
perf.data
perf.data.old

# Doxygen generated documentation
docs/api/

# ===== Testing =====

# Log files
*.log

# Core dumps
core
core.*
vgcore.*

# Sanitizer output
asan.log.*
msan.log.*
tsan.log.*
ubsan.log.*

# Fuzz corpus & crash artifacts (tracked selectively if needed)
fuzz/crash-*
fuzz/leak-*
fuzz/timeout-*
fuzz/oom-*
fuzz/slow-unit-*

# ===== Dependency managers =====

# Conan
conanbuildinfo.*
conaninfo.txt
graph_info.json
conan.lock
CMakeUserPresets.json

# vcpkg
vcpkg_installed/

# ===== OS artifacts =====

# macOS
.DS_Store
._*
__MACOSX/

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ===== IDE / editor =====

# Vim / Neovim
*.swp
*.swo
*.swn
tags
Session.vim

# VS Code
.vscode/

# JetBrains (CLion, etc.)
.idea/

# Xcode
*.xcodeproj/
*.xcworkspace/
xcuserdata/

# Qt Creator
CMakeLists.txt.user*

# compile_commands.json (generated by CMake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON)
compile_commands.json

# ccls / clangd index caches
.ccls-cache/
.cache/
.clangd/

# ===== Windows build artifacts (MinGW-w64) =====

*.exe
*.pdb
*.ilk
*.iobj
*.ipdb

# ===== Packaging =====

# CPack output
*.deb
*.rpm
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip
# Keep source archives created intentionally (Makefile devel-snapshot)
!*.src.tar.gz

# ===== Misc =====

# Python bytecode (conanfile.py, scripts)
__pycache__/
*.pyc
*.pyo

# Secrets / credentials (should never be committed)
*.pem
*.key
!packaging/**/*.key

# Docker compose overrides (local only)
docker-compose.override.yml

# Claude Code
.claude/
